@startuml HRS_BCE_ClassDiagram
' ホテル予約システム 設計クラス図（Boundary-Control-Entity）
' ★演習6 = 予約キャンセル拡張で追加した要素
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam classBackgroundColor #FDFDFD
skinparam packageBackgroundColor #F5F5F5
hide circle

package "Boundary（画面・UI）" {
  class 宿泊予約画面 {
    +部屋を選択する()
    +予約番号を表示する()
  }
  class 宿泊部屋検索画面 {
    +部屋検索条件を入力する()
    +空室一覧を表示する()
    +警告を表示する()
  }
  class 部屋管理画面 {
    +部屋情報を入力する()
    +全部屋を表示する()
  }
  class チェックイン画面 {
    +予約番号を入力する(予約番号: int)
    +予約情報を表示する()
    +部屋を選択して確定する(部屋番号: int)
  }
  class チェックアウト画面 {
    +部屋番号を入力する(部屋番号: int)
    +支払いを確定する()
  }
  class 予約キャンセル画面 <<演習6>> {
    +予約番号を入力する(予約番号: int)
    +予約情報を表示する()
    +キャンセルを確定する()
  }
}

package "Control（処理・コントローラ）" {
  class 宿泊予約処理 {
    +部屋を予約する()
  }
  class 宿泊部屋検索処理 {
    +部屋を検索する()
    +部屋の空室を確認する()
    +空室一覧を作成する(): List<部屋>
  }
  class 部屋管理処理 {
    +部屋を追加する()
    +全部屋を取得する(): List<部屋>
  }
  class チェックイン制御 {
    +予約を検索する(予約番号: int): 予約
    +チェックイン完了を指示する(部屋番号: int)
  }
  class チェックアウト制御 {
    +宿泊データを検索する(部屋番号: int): 宿泊
    +チェックアウトを完了する()
  }
  class 予約キャンセル制御 <<演習6>> {
    +予約を検索する(予約番号: int): 予約
    +予約キャンセルを完了する(予約番号: int)
  }
}

package "Entity（ドメイン・データ）" {
  class 利用者 {
    -利用者名: String
  }
  class 予約 {
    -予約番号: int
    -予約宿泊予定日: DateTime
    -状態: String
    +予約を作成する()
    +予約番号を発行する(): int
    +予約詳細を取得する(): 予約
    +状態を「宿泊中」にする()
    +状態を「キャンセル」にする() <<演習6>>
  }
  class 部屋 {
    -部屋番号: int
    -部屋タイプ: String
    -基本宿泊料: int
    -空室状態: boolean
    +部屋番号を作成する(部屋番号: int)
    +部屋タイプを作成する(部屋タイプ: String)
    +宿泊料を作成する(宿泊料: int)
    +[空室数>0]部屋を取得する(): 部屋
    +空室数を1減らす()
    +部屋を使用中にする()
    +部屋を空室にする()
    +基本宿泊料を取得する(): int
  }
  class 宿泊 {
    -イン日時: DateTime
    -アウト日時: DateTime
    +宿泊記録を生成する()
    +滞在詳細を取得する(): 宿泊
    +アウト日時を記録する(現在日時: DateTime)
  }
  class 支払い {
    -支払い料金: int
    +支払い記録を生成する(支払い料金: int)
  }
  class ホテル受付係 {
    -名前: String
  }

  利用者 "1" -- "*" 予約 : 予約する >
  予約 "*" --> "1" 部屋 : 対象 >
  部屋 "1" -- "0..1" 宿泊 : 記録 >
  宿泊 "1" -- "1" 支払い : 精算 >
  ホテル受付係 "1" -- "*" 宿泊 : 対応 >
}

' --- Boundary → Control ---
宿泊予約画面 ..> 宿泊予約処理
宿泊部屋検索画面 ..> 宿泊部屋検索処理
部屋管理画面 ..> 部屋管理処理
チェックイン画面 ..> チェックイン制御
チェックアウト画面 ..> チェックアウト制御
予約キャンセル画面 ..> 予約キャンセル制御

' --- Control → Entity ---
宿泊予約処理 ..> 予約
宿泊予約処理 ..> 部屋
宿泊部屋検索処理 ..> 部屋
部屋管理処理 ..> 部屋
チェックイン制御 ..> 予約
チェックイン制御 ..> 部屋
チェックイン制御 ..> 宿泊
チェックアウト制御 ..> 宿泊
チェックアウト制御 ..> 部屋
チェックアウト制御 ..> 支払い
予約キャンセル制御 ..> 予約
予約キャンセル制御 ..> 部屋
@enduml
